# ─────────────────────────────────────────────────────────────
# Frontend Environment Variables
#
# Copy this file to `.env` and fill in your Worker URL.
# The .env file is NOT committed to version control.
# ─────────────────────────────────────────────────────────────

# The full URL of your deployed Cloudflare Worker.
# Example (local dev):  http://localhost:8787
# Example (production): https://cf-ai-chatapp-worker.YOUR_SUBDOMAIN.workers.dev
VITE_WORKER_URL=https://your-worker.your-subdomain.workers.dev
